acrontab -e
*/10 * * * * lxplus.cern.ch [scripts_dir]/cronjob_EM.sh [working_dir] [UserInputDir]/UserInput_2021_EAR2_Commissioning_v0.2.h [eos_outdir] auto > [working_dir]/cronjob.out 2>&1

